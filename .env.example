# Database Configuration
POSTGRES_PASSWORD=changeme_secure_password

# JWT Configuration
JWT_SECRET=your-very-secure-jwt-secret-key-change-in-production

# OAuth2 Configuration (for SSO)
OAUTH2_CLIENT_ID=your-oauth2-client-id
OAUTH2_CLIENT_SECRET=your-oauth2-client-secret

# SAML Configuration (for Enterprise SSO)
SAML_ENTITY_ID=foodsecuritynet
SAML_IDP_METADATA_URL=https://your-idp.com/metadata

# LLM API Keys
HF_API_KEY=your-huggingface-api-key
XAI_API_KEY=your-xai-api-key
LLM_MODEL_NAME=gpt2

# AI Model Configuration
AI_WORKERS=4

# MFA Configuration
MFA_ISSUER=FoodSecurityNet
MFA_ENABLED=true

# Email Configuration (for MFA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@foodsecuritynet.org

# External API Keys
FAO_API_KEY=your-fao-api-key
NOAA_API_KEY=your-noaa-api-key
USDA_API_KEY=your-usda-api-key

# Monitoring
ENABLE_METRICS=true
GRAFANA_ADMIN_PASSWORD=admin
