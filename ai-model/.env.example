# Model Configuration
MODEL_PATH=model.pt
MODEL_VERSION=1.0.0

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# Resource Thresholds
MIN_CPU_CORES_FOR_MULTIPROCESSING=4
MIN_MEMORY_GB_FOR_MULTIPROCESSING=8

# Model Hyperparameters
INPUT_SIZE=50
OUTPUT_SIZE=15
DROPOUT_RATE=0.3

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=100
VALIDATION_SPLIT=0.2
